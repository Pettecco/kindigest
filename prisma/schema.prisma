generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleType      = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  email                String               @unique
  passwordHash         String
  hashedRefreshToken   String?
  preferredDisplayMode PreferredDisplayMode @default(TRANSLATED)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

enum PreferredDisplayMode {
  IMMERSIVE
  TRANSLATED
}
