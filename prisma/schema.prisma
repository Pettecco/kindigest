generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  moduleType = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  email                String               @unique @db.VarChar(255)
  passwordHash         String               @db.VarChar(255)
  hashedRefreshToken   String?              @db.VarChar(255)
  preferredDisplayMode PreferredDisplayMode @default(TRANSLATED)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  imports              Imports[]
  vocabulary           Vocabulary[]
}

model Imports {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @db.Uuid
  importedAt DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary[]
}

model Books {
  id           String       @id @default(uuid()) @db.Uuid
  kindleBookId String       @unique @db.VarChar(100)
  title        String       @db.VarChar(255)
  author       String      @db.VarChar(255)
  vocabulary   Vocabulary[]
}

model Words {
  id             String       @id @default(uuid()) @db.Uuid
  word           String       @db.VarChar(100)
  stem           String?      @db.VarChar(100)
  language       Language     @default(PT)
  translatedWord String?      @db.VarChar(255)
  vocabulary     Vocabulary[]
  definition     Definitions?

  @@unique([word, language])
}

model Definitions {
  id                   String   @id @default(uuid()) @db.Uuid
  wordId               String   @unique @db.Uuid
  definition           String?  @db.VarChar(2000)
  translatedDefinition String?  @db.VarChar(2000)
  source               String?  @db.VarChar(100)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  word                 Words    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
}

model TranslationUsage {
  id        String @id @default(uuid()) @db.Uuid
  month     Int // ex: 202606
  charsUsed Int    @default(0)
  limit     Int    @default(500000)

  @@unique([month])
}

model Vocabulary {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  importId   String   @db.Uuid
  bookId     String   @db.Uuid
  wordId     String   @db.Uuid
  context    String?  @db.VarChar(2000)
  learnCount Int      @default(0)
  createdAt  DateTime @default(now())
  book       Books    @relation(fields: [bookId], references: [id])
  import     Imports  @relation(fields: [importId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word       Words    @relation(fields: [wordId], references: [id])

  @@unique([userId, bookId, wordId])
  @@index([userId, createdAt])
  @@index([userId, learnCount])
}

enum PreferredDisplayMode {
  IMMERSIVE
  TRANSLATED
}

enum Language {
  EN
  PT
  ES
  FR
}
