{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^generated/(.*)$": "<rootDir>/generated/$1"
  },
  "coverageDirectory": "coverage",
  "collectCoverageFrom": ["src/**/*.ts"],
  "coveragePathIgnorePatterns": [
    ".module.ts$",
    ".controller.ts$",
    ".dto.ts$",
    "main.ts",
    "index.ts",
    "prisma.service.ts",
    "/infrastructure/",
    "/mappers/",
    "/repositories/",
    "/guards/",
    "/decorators/",
    "/config/",
    "/domain/entities/",
    "/factories/",
    "/external/",
    ".constants.ts$",
    ".interface.ts$",
    "log-options.ts"
  ],
  "coverageProvider": "v8",
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 70,
      "lines": 75,
      "statements": 75
    }
  }
}
